# =============================================================================
# BRIDGING GENERATIONS — Environment variables
# Copy to .env.local for development. Set all in Vercel for preview + production.
# Everything is optional in dev; the app falls back to safe defaults.
# =============================================================================


# ---- Site ----
# Canonical site URL — used for JSON-LD, sitemap, OG image base.
# Defaults to the production domain when unset.
NEXT_PUBLIC_SITE_URL=http://localhost:3001


# ---- Keystatic CMS ----
# Required for production: enables GitHub-backed content edits via /keystatic.
# In dev, leaving these unset falls back to local filesystem storage (safe).
# Create the OAuth app at https://github.com/settings/developers
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
# 32+ random chars for session cookie signing. Generate with: openssl rand -base64 32
KEYSTATIC_SECRET=
# Optional: override callback domain if it differs from the deploy URL
KEYSTATIC_URL=


# ---- Database (Neon Postgres) ----
# Created via Vercel Marketplace → Storage → Neon. Vercel auto-injects this
# var; copy it here for local dev. Drizzle reads DATABASE_URL.
DATABASE_URL=
# Optional: separate pooled URL for serverless functions
DATABASE_POOL_URL=


# ---- Auth (Clerk) ----
# Created at https://dashboard.clerk.com. Free tier covers up to 10k MAU.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Webhook signing secret — set after configuring the Clerk webhook endpoint
CLERK_WEBHOOK_SECRET=
# Optional: customize sign-in / sign-up routes
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard


# ---- Payments (Stripe) ----
# Owner already has Stripe. Find these at https://dashboard.stripe.com/apikeys
# Use TEST keys (sk_test_…, pk_test_…) in dev; LIVE keys only in prod.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
# Webhook signing secret — set after configuring the webhook endpoint in Stripe.
# Endpoint URL will be {NEXT_PUBLIC_SITE_URL}/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=


# ---- Email (Resend) ----
# Sign up at https://resend.com. Free tier: 100/day, 3000/month.
# Domain must be verified before sending from a custom address.
RESEND_API_KEY=
# From-address for transactional email (contact form, application receipts).
# Without it, the contact route logs to stderr in dev and returns success.
RESEND_FROM_EMAIL=
# Destination address for contact-form + application submissions.
# Falls back to siteSettings.contactEmail in Keystatic when unset.
CONTACT_DESTINATION_EMAIL=bridginggeneration20@gmail.com


# ---- File storage (Vercel Blob) ----
# Created via Vercel Dashboard → Storage → Blob. Auto-injected on Vercel.
BLOB_READ_WRITE_TOKEN=


# ---- bKash (DEFERRED — not used in v1) ----
# Architected as pluggable. Fill these in only when bKash merchant account is approved.
# BKASH_USERNAME=
# BKASH_PASSWORD=
# BKASH_APP_KEY=
# BKASH_APP_SECRET=
# BKASH_MODE=sandbox
