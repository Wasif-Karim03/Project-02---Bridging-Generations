{
  "name": "site",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0 <25"
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not op_mini all",
    "not safari < 16"
  ],
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "analyze": "ANALYZE=1 next build --webpack",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:a11y": "playwright test tests/e2e/*-a11y.spec.ts --project=chromium",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.3.3",
    "@keystatic/core": "0.5.50",
    "@keystatic/next": "5.0.4",
    "@react-pdf/renderer": "^4.5.1",
    "@stripe/stripe-js": "^9.5.0",
    "drizzle-orm": "^0.45.2",
    "exceljs": "^4.4.0",
    "lenis": "^1.3.23",
    "lucide-react": "^1.11.0",
    "motion": "^12.38.0",
    "next": "16.2.4",
    "next-intl": "^4.12.0",
    "next-mdx-remote": "6.0.0",
    "next-view-transitions": "^0.3.5",
    "postgres": "^3.4.9",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "4.0.1",
    "resend": "^6.12.2",
    "stripe": "^22.1.1"
  },
  "overrides": {
    "svix": "^1.92.2",
    "postcss": "^8.5.10"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@axe-core/react": "^4.11.2",
    "@biomejs/biome": "2.4.13",
    "@next/bundle-analyzer": "^16.2.4",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^29.1.0",
    "tailwindcss": "^4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
